<robot name="triple_pendulum_modified">

    <!-- ================= MATERIALS ================= -->
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>
    <material name="gray">
        <color rgba="0.4 0.4 0.4 1"/>
    </material>

    <!-- ================= LINKS ================= -->
    <link name="world"/>

    <link name="base">
        <visual>
            <geometry>
                <sphere radius="0.1"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <!-- ===== LINK 1 ===== -->
    <link name="link_1">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.4"/>
            </geometry>
            <origin xyz="0 0 0.2"/>
            <material name="gray"/>
        </visual>
    </link>

    <!-- ===== LINK 2 ===== -->
    <link name="link_2">
        <visual>
            <geometry>
                <cylinder radius="0.01" length="0.4"/>
            </geometry>
            <origin xyz="0 0 0.2"/>
            <material name="gray"/>
        </visual>
    </link>

    <!-- ===== ROTATION LINK (NO LENGTH) ===== -->
    <link name="link_3">
        <visual>
            <geometry>
                <sphere radius="0.01"/>
            </geometry>
            <material name="gray"/>
        </visual>
    </link>

    <!-- ===== END EFFECTORS (MASS POINTS) ===== -->
    <link name="link_eef_1">
        <visual>
            <geometry>
                <sphere radius="0.03"/>
            </geometry>
            <origin xyz="0 0 0.03"/>
            <material name="black"/>
        </visual>
    </link>

    <link name="link_eef_2">
        <visual>
            <geometry>
                <sphere radius="0.03"/>
            </geometry>
            <origin xyz="0 0 0.03"/>
            <material name="black"/>
        </visual>
    </link>

    <!-- ===== CAMERA ===== -->
    <link name="camera_link">
        <visual>
            <geometry>
                <box size="0.05 0.03 0.02"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <!-- ================= JOINTS ================= -->

    <joint name="world_to_base" type="fixed">
        <parent link="world"/>
        <child link="base"/>
        <origin xyz="0 0 3"/>
    </joint>

    <!-- ===== JOINT 1 ===== -->
    <joint name="joint_1" type="revolute">
        <parent link="base"/>
        <child link="link_1"/>
        <origin rpy="0 1.57 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
        <dynamics damping="0.001"/>
    </joint>

    <joint name="eef_joint_1" type="fixed">
        <parent link="link_1"/>
        <child link="link_eef_1"/>
        <origin xyz="0 0 0.4"/>
    </joint>

    <!-- ===== JOINT 2 ===== -->
    <joint name="joint_2" type="revolute">
        <parent link="link_eef_1"/>
        <child link="link_2"/>
        <origin rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
        <dynamics damping="0.001"/>
    </joint>

    <joint name="eef_joint_2" type="fixed">
        <parent link="link_2"/>
        <child link="link_eef_2"/>
        <origin xyz="0 0 0.4"/>
    </joint>

    <!-- ===== JOINT 3 (ROTATION ONLY) ===== -->
    <joint name="joint_3" type="revolute">
        <parent link="link_eef_2"/>
        <child link="link_3"/>
        <origin xyz="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
        <dynamics damping="0.001"/>
    </joint>

    <!-- ===== CAMERA MOUNT (NO OFFSET) ===== -->
    <joint name="camera_joint" type="fixed">
        <parent link="link_3"/>
        <child link="camera_link"/>
        <origin xyz="0 0 0" rpy="1.57079632679 3.14159265359 3.14159265359"/>
    </joint>

</robot>